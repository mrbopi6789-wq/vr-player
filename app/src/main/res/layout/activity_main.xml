<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- HOME SCREEN -->
    <LinearLayout
        android:id="@+id/homeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#000000"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🥽"
            android:textSize="72sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VR PLAYER"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIDE BY SIDE · 3D SPLIT SCREEN"
            android:textColor="#888888"
            android:textSize="12sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="48dp" />

        <LinearLayout
            android:id="@+id/btnPickVideo"
            android:layout_width="220dp"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_btn_play"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PICK A VIDEO"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to choose a video from your gallery"
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Put your phone in your VR headset after the video starts"
            android:textColor="#444444"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="40dp" />

    </LinearLayout>

    <!-- PLAYER SCREEN — black background with centered video container -->
    <FrameLayout
        android:id="@+id/playerScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone">

        <!-- Video container — this is what gets scaled with +/- buttons -->
        <LinearLayout
            android:id="@+id/videoContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:background="#000000">

            <!-- LEFT EYE -->
            <SurfaceView
                android:id="@+id/surfaceLeft"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <!-- CENTER DIVIDER -->
            <View
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:background="#000000" />

            <!-- RIGHT EYE -->
            <SurfaceView
                android:id="@+id/surfaceRight"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

        </LinearLayout>

    </FrameLayout>

    <!-- TAP OVERLAY -->
    <View
        android:id="@+id/tapOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- CONTROLS OVERLAY -->
    <LinearLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_controls_gradient"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <!-- Video title -->
        <TextView
            android:id="@+id/tvVideoName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Video"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginBottom="8dp" />

        <!-- Seek bar -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="#1D9BF0"
            android:thumbTint="#1D9BF0"
            android:layout_marginBottom="8dp" />

        <!-- Bottom controls row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Current time -->
            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#CCCCCC"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / "
                android:textColor="#666666"
                android:textSize="12sp" />

            <!-- Total time -->
            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00"
                android:textColor="#CCCCCC"
                android:textSize="12sp" />

            <!-- MINUS button — shrink video -->
            <TextView
                android:id="@+id/btnZoomOut"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="−"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:gravity="center"
                android:background="@drawable/bg_btn_control"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <!-- Screen size indicator -->
            <TextView
                android:id="@+id/tvScreenSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='7.0"'
                android:textColor="#1D9BF0"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                android:minWidth="36dp"
                android:gravity="center" />

            <!-- PLUS button — grow video -->
            <TextView
                android:id="@+id/btnZoomIn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="+"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:gravity="center"
                android:background="@drawable/bg_btn_control"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <!-- Back button -->
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:gravity="center"
                android:background="@drawable/bg_btn_control"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <!-- Play/Pause button -->
            <TextView
                android:id="@+id/btnPlayPause"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:text="⏸"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@drawable/bg_btn_playpause"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <!-- Settings button -->
            <TextView
                android:id="@+id/btnSettings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="⚙"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@drawable/bg_btn_control"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
